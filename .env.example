# Copy this file to .env and fill in your key.
# Production users save this securely in macOS Keychain from MeetingNotes.
# For development, MeetingNotes loads GROQ_API_KEY from the process environment,
# the app bundle (.env copied at build time), the current directory,
# ~/Documents/MeetingNotes/.env, and ~/.meetingnotes/.env.
GROQ_API_KEY=gsk_your_groq_api_key_here
